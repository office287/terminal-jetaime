{
  "name": "terminal-jetaime",
  "version": "1.0.0",
  "scripts": {
    "start": "node server.js",
    "improve": "node scripts/nightly-improve.js",
    "nightly": "node scripts/nightly-improve.js && node scripts/morning-report.js --force",
    "report": "node scripts/morning-report.js",
    "report:force": "node scripts/morning-report.js --force",
    "report:no-send": "node scripts/morning-report.js --no-send",
    "traffic": "node scripts/daily-report.js",
    "stats": "node scripts/stats-daily.js",
    "stats:force": "node scripts/stats-daily.js --force",
    "stats:print": "node scripts/stats-daily.js --print --no-send"
  },
  "dependencies": { "express": "^4.18.2", "morgan": "^1.10.0", "geoip-lite": "^1.4.10", "pdfkit": "^0.15.0", "googleapis": "^144.0.0" },
  "engines": { "node": ">=18.0.0" }
}
